{
  "manifest_version": 3,
  "name": "YouTube Focus Timer",
  "version": "2.0",

  "permissions": ["activeTab", "scripting"],

  "host_permissions": ["https://www.youtube.com/*"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}